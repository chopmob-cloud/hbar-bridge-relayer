# =============================================================
# ALGO → HBAR  Relayer  (algo_to_hbar/relayer.py)
# =============================================================

# ── Algorand (source) ─────────────────────────────────────────
# Algorand Indexer endpoint
ALGO_INDEXER_URL=https://mainnet-idx.algonode.cloud

# App ID of the Algorand escrow smart contract that emits deposit logs
ALGO_ESCROW_APP_ID=

# Log prefix the escrow contract appends before the payload bytes
# Must match what the AVM contract encodes in its log
LOG_PREFIX=HBAR_DEP_V1|

# ── Hedera (destination) ──────────────────────────────────────
# mainnet | testnet
HEDERA_NETWORK=mainnet

# Hedera operator account that pays transaction fees and signs transfers
# Format: shard.realm.num  e.g. 0.0.12345
HEDERA_OPERATOR_ID=

# ED25519 or ECDSA DER-encoded private key for the operator account
HEDERA_OPERATOR_KEY=

# Treasury account that holds the bridged tokens on Hedera
# Usually the same as HEDERA_OPERATOR_ID
HEDERA_TREASURY_ID=

# HTS token ID to transfer  e.g. 0.0.99999
# Leave blank to transfer native HBAR (tinybars)
HEDERA_TOKEN_ID=

# Hedera Mirror Node base URL
HEDERA_MIRROR_URL=https://mainnet-public.mirrornode.hedera.com

# ── Relayer controls ──────────────────────────────────────────
# Seconds between Algorand indexer polls
POLL_DELAY=15

# Algorand confirmation depth before processing a deposit
CONFIRM_ROUNDS=6

# Per-deposit safety cap in base units (0 = no cap)
MAX_DEPOSIT=0

# Alert threshold for treasury balance (0 = no alert). Logs [ALERT] when balance drops below this.
TREASURY_ALERT_THRESHOLD=0

# Persistent state files
CURSOR_FILE=/opt/relayers/algo_to_hbar/cursor_round.txt
RECEIPT_DB=/opt/relayers/algo_to_hbar/receipts.db


# =============================================================
# HBAR → ALGO  Relayer  (hbar_to_algo/relayer.py)
# =============================================================

# ── Hedera (source) ───────────────────────────────────────────
# Hedera Mirror Node base URL
HEDERA_MIRROR_URL=https://mainnet-public.mirrornode.hedera.com

# EVM-compatible Hedera smart contract that accepts deposits
# Format: shard.realm.num  e.g. 0.0.55555
HEDERA_CONTRACT_ID=

# keccak256 of the Solidity event signature that carries bridge data
# e.g. keccak256("BridgeDeposit(bytes)") — fill in after contract deploy
# Leave blank to match all logs from the contract
HEDERA_TOPIC0=

# Log prefix packed inside the event data by the Solidity contract
HBAR_LOG_PREFIX=HBAR_BRIDGE_DEP_V1|

# ── Algorand (destination) ────────────────────────────────────
# Algod endpoint and optional token
ALGO_ALGOD_ADDRESS=https://mainnet-api.algonode.cloud
ALGO_ALGOD_TOKEN=

# App ID of the Algorand escrow smart contract (must match algo_to_hbar above)
ALGO_ESCROW_APP_ID=

# Algorand Standard Asset (ASA) ID of the bridged token
ALGO_TOKEN_ASA_ID=

# 25-word mnemonic of the Algorand admin/relayer wallet
ALGO_ADMIN_MNEMONIC=

# ── Relayer controls ──────────────────────────────────────────
# Seconds between Hedera Mirror Node polls
POLL_DELAY=20

# Maximum exponential-backoff ceiling in seconds
MAX_BACKOFF=180

# Algorand confirmation depth
ALGO_CONFIRM_ROUNDS=12

# Mirror Node page size per poll
INDEXER_LIMIT=25

# Log verbosity: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Per-deposit safety cap in base units (0 = no cap)
MAX_DEPOSIT=0

# How many seconds back from chain head to start if cursor file is absent
AUTO_START_LOOKBACK=300

# Persistent state files
CURSOR_FILE=/opt/relayers/hbar_to_algo/cursor_timestamp.txt
RECEIPT_DB=/opt/relayers/hbar_to_algo/receipts.db
